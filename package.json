{
    "private": true,
    "packageManager": "pnpm@9.0.0",
    "type": "module",
    "scripts": {
        "build": "node ./scripts/plugin-styles.mjs --build && vite build",
        "build:styles": "node ./scripts/plugin-styles.mjs --build",
        "dev": "concurrently -n vite,styles -c blue,magenta \"vite\" \"node ./scripts/plugin-styles.mjs --watch\"",
        "dev:styles": "node ./scripts/plugin-styles.mjs --watch"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.4",
        "@tailwindcss/postcss": "^4.2.4",
        "@tailwindcss/vite": "^4.2.4",
        "autoprefixer": "^10.5.0",
        "axios": "^1.15.2",
        "concurrently": "^9.2.1",
        "follow-redirects": "^1.16.0",
        "laravel-vite-plugin": "^1.0",
        "picomatch": "^2.3.2",
        "postcss": "^8.5.10",
        "rollup": "^4.60.2",
        "sass": "^1.99.0",
        "tailwindcss": "^4.2.4",
        "vite": "^6.4.2"
    },
    "pnpm": {
        "overrides": {
            "@parcel/watcher": "2.5.6",
            "axios": "1.15.2",
            "brace-expansion": "1.1.14",
            "follow-redirects": "1.16.0",
            "minimatch": "3.1.5",
            "picomatch": "2.3.2"
        }
    }
}
