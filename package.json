{
    "private": true,
    "packageManager": "pnpm@9.0.0",
    "type": "module",
    "scripts": {
        "build": "node ./scripts/plugin-styles.mjs --build && vite build",
        "build:styles": "node ./scripts/plugin-styles.mjs --build",
        "dev": "concurrently -n vite,styles -c blue,magenta \"vite\" \"node ./scripts/plugin-styles.mjs --watch\"",
        "dev:styles": "node ./scripts/plugin-styles.mjs --watch"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.3.2",
        "@tailwindcss/postcss": "^4.3.2",
        "@tailwindcss/vite": "^4.3.2",
        "autoprefixer": "^10.5.0",
        "axios": "^1.16.0",
        "concurrently": "^9.2.1",
        "follow-redirects": "^1.16.0",
        "laravel-vite-plugin": "^1.0",
        "picomatch": "^2.3.2",
        "postcss": "^8.5.10",
        "rollup": "^4.60.2",
        "sass": "^1.99.0",
        "tailwindcss": "^4.3.2",
        "vite": "^6.4.3"
    },
    "pnpm": {
        "overrides": {
            "@parcel/watcher": "2.5.6",
            "axios": "1.16.0",
            "brace-expansion": "1.1.14",
            "follow-redirects": "1.16.0",
            "minimatch": "3.1.5",
            "picomatch": "2.3.2",
            "fast-uri@<=3.1.0": "3.1.3",
            "fast-uri@<=3.1.1": "3.1.3",
            "shell-quote@>=1.1.0 <=1.8.3": "1.8.4",
            "js-cookie@<=3.0.5": "3.0.8",
            "form-data@>=4.0.0 <4.0.6": "4.0.6",
            "vite@<=6.4.2": "6.4.3"
        }
    }
}
